# Database Configuration
DATASOURCE_URL=jdbc:postgresql://tcp.cloudpub.ru:15432/postgres
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=your_password_here

# Mail Configuration (Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Frontend URL
FRONTEND_URL=https://kanbandocky.ru

# Turnstile (Cloudflare)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# OAuth2 Redirect URI (base URL for all OAuth providers)
OAUTH_REDIRECT_URI=https://kanbandocky.ru

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Yandex OAuth2
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# GitHub OAuth2
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_characters_long
